Day 02 — Services & Tags

🔹 Ansible — Install & Enable Nginx

- name: Install ans start Nginx on Pathnex
  host: all
  become: yes

  tasks:
    - name: Install nginx
      yum:
        name: nginx
        state: present
    
    - name: Enable nginx
      service:
        name: nginx
        state: started
        enabled: yes


